# ============================================================================
# KL PERFUMES RD — Variables de entorno requeridas
# Copia este archivo como ".env" y completa los valores. NUNCA subas .env a Git.
# Para producción, configura estas variables en el dashboard de Vercel.
# ============================================================================

# ----------------------------------------------------------------------------
# BASE DE DATOS (SQL Server — requerido)
# IMPORTANTE para producción: el servidor SQL debe ser accesible desde internet.
# Opciones: IP pública con firewall abierto en puerto 1433, o Azure SQL Database.
# trustServerCertificate=false en producción con certificado SSL válido.
# ----------------------------------------------------------------------------
DATABASE_URL="sqlserver://<HOST>:1433;database=KLPerfumesDB;user=<USER>;password=<PASSWORD>;encrypt=true;trustServerCertificate=true"

# ----------------------------------------------------------------------------
# SESIÓN ADMIN (requerido)
# Genera con: openssl rand -base64 32
# ----------------------------------------------------------------------------
SESSION_SECRET="<secreto-aleatorio-minimo-32-caracteres>"

# ----------------------------------------------------------------------------
# SITIO (requerido)
# ----------------------------------------------------------------------------
NEXT_PUBLIC_SITE_URL="https://klperfumesrd.com"

# ----------------------------------------------------------------------------
# DATOS DE CONTACTO — visibles en el sitio
# ----------------------------------------------------------------------------
NEXT_PUBLIC_WA_NUMBER="1809XXXXXXX"
NEXT_PUBLIC_STORE_EMAIL="info@klperfumesrd.com"
NEXT_PUBLIC_STORE_PHONE_DISPLAY="+1 (809) XXX-XXXX"

# ----------------------------------------------------------------------------
# ASISTENTE VIRTUAL KLia (Google Gemini) — opcional
# Obtén tu API key en: https://aistudio.google.com/apikey
# ----------------------------------------------------------------------------
GEMINI_API_KEY="AIza..."
GEMINI_MODEL="gemini-2.5-flash"

# ----------------------------------------------------------------------------
# EMAILS TRANSACCIONALES (Resend) — opcional
# 1. Crea cuenta en https://resend.com y obtén una API key
# 2. Verifica el dominio klperfumesrd.com en Resend
# 3. Actualiza RESEND_FROM con el email verificado
# Si no se configura, el envío de emails se omite silenciosamente.
# ----------------------------------------------------------------------------
RESEND_API_KEY="re_..."
RESEND_FROM="KL Perfumes RD <confirmaciones@klperfumesrd.com>"

# ----------------------------------------------------------------------------
# ALMACENAMIENTO (pendiente — futuras fases)
# ----------------------------------------------------------------------------
BLOB_STORAGE_URL="pendiente"
BLOB_STORAGE_TOKEN="pendiente"
